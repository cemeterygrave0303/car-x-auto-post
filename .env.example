# Google Sheets API 設定
# サービスアカウントJSONファイルのパス（またはJSONの中身を直接貼り付け可）
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# 対象スプレッドシートのID（URLの /d/〜/edit の間の文字列）
SPREADSHEET_ID=1rlArsppsqnmfwqd7EU-CneYvu79Ipr3TWl8Ufngy4Ns

# 読み込むシート名（タブ名）
SHEET_NAME=在庫一覧

# X (Twitter) API 設定
# X Developer Portal の "Keys and Tokens" から取得する
# ※ コンシューマーキー / コンシューマーシークレット
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# ※ アクセストークン / アクセストークンシークレット（Read and Write 権限で生成すること）
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Google Drive アップロード先フォルダID（省略時は「中古車_写真」フォルダを自動作成）
# DRIVE_FOLDER_ID=your_folder_id_here

# DRY RUN モード（true の場合 X には投稿せず投稿文だけ表示する）
DRY_RUN=false

# ログファイルパス（省略可）
LOG_FILE=logs/app.log
